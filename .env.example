# 根目录环境变量模板
# 本文件用于复制生成本机 .env；真实生产密钥不得写入 Git。

# 本地开发环境
# 常规本地界面开发默认连接已经由 dev 分支自动部署的远端网关。
BIFROST_ENV=development

# 远端 dev 后端
BIFROST_PUBLIC_BASE_URL=http://142.171.208.80:18080
BIFROST_ADMIN_BASE_URL=http://127.0.0.1:5173
# 后台本地开发时浏览器请求同源代理前缀，Vite 再转发到 BIFROST_REMOTE_DEV_GATEWAY_URL，避免跨域。
VITE_GATEWAY_BASE_URL=/__bifrost_gateway__
VITE_GATEWAY_DEV_PROXY_BASE_URL=/__bifrost_gateway__
BIFROST_REMOTE_DEV_GATEWAY_URL=http://142.171.208.80:18080

# 本地应用端口
# BIFROST_ADMIN_DEV_PORT 控制 apps/admin 的 Vite 开发服务端口。
# BIFROST_DESKTOP_DEV_PORT 控制 apps/desktop 的 Electron 渲染层开发服务端口。
# PORT 控制本机显式启动 Gateway 进程时的监听端口。
BIFROST_ADMIN_DEV_PORT=5173
BIFROST_DESKTOP_DEV_PORT=22473
PORT=8080

# 可选本机 Docker 端口
# 这些默认值只服务显式本机 Docker 编排；正常执行 pnpm dev:backend 不会启动 Docker。
BIFROST_DEV_GATEWAY_PORT=8080
BIFROST_DEV_ADMIN_PORT=5173
BIFROST_DEV_POSTGRES_PORT=5432

# 后端运行时
BIFROST_DATABASE_URL=postgres://bifrost:bifrost@127.0.0.1:5432/bifrost?sslmode=disable
BIFROST_TOKEN_SECRET=local-development-bifrost-token-secret-32bytes
BIFROST_ACCESS_TOKEN_TTL=15m
BIFROST_REFRESH_TOKEN_TTL=720h
BIFROST_AUDIT_RETENTION_DAYS=180
BIFROST_UPSTREAM_GITLAB=http://mock-gitlab:8080
BIFROST_UPSTREAM_JENKINS=http://mock-jenkins:8080
BIFROST_UPSTREAM_DOCS=http://mock-docs:8080
BIFROST_UPSTREAM_INTERNAL_ADMIN=http://mock-internal-admin:8080

# 测试环境
# 端到端测试和后端校验脚本默认会分配隔离端口。
# 只有需要从命令行强制指定测试端口时，才取消下列注释。
# BIFROST_DEV_GATEWAY_PORT=18080
# BIFROST_DEV_ADMIN_PORT=15173
# BIFROST_DEV_POSTGRES_PORT=15432
# BIFROST_DATABASE_TEST_URL=postgres://bifrost:bifrost@127.0.0.1:15432/postgres?sslmode=disable

# dev 分支自动部署
# 这些值属于 GitHub Actions 密钥或变量，不应写入已提交文件。
# BIFROST_DEV_DEPLOY_HOST=142.171.208.80
# BIFROST_DEV_DEPLOY_PORT=48222
# BIFROST_DEV_DEPLOY_USER=root
# BIFROST_DEV_DEPLOY_PATH=/opt/bifrost-dev
# BIFROST_DEV_DEPLOY_KEY=<github-actions-secret-only>

# 生产环境
# 生产环境必须使用真实域名、私有数据库地址和密钥管理系统里的强随机密钥。
# BIFROST_ENV=production
# BIFROST_PUBLIC_BASE_URL=https://gateway.example.com
# BIFROST_ADMIN_BASE_URL=https://admin.example.com
# VITE_GATEWAY_BASE_URL=https://gateway.example.com
# BIFROST_DATABASE_URL=postgres://bifrost:<secret>@postgres:5432/bifrost?sslmode=require
# BIFROST_TOKEN_SECRET=<use-a-secret-manager-value-at-least-32-chars>
# PORT=8080
# BIFROST_ACCESS_TOKEN_TTL=15m
# BIFROST_REFRESH_TOKEN_TTL=720h
# BIFROST_AUDIT_RETENTION_DAYS=180
