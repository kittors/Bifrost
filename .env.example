BIFROST_ENV=development
BIFROST_PUBLIC_BASE_URL=http://localhost:8080
BIFROST_ADMIN_BASE_URL=http://localhost:5173
BIFROST_DATABASE_URL=postgres://bifrost:bifrost@localhost:5432/bifrost?sslmode=disable
BIFROST_TOKEN_SECRET=local-development-bifrost-token-secret-32bytes
BIFROST_ACCESS_TOKEN_TTL=15m
BIFROST_REFRESH_TOKEN_TTL=720h
BIFROST_AUDIT_RETENTION_DAYS=180
BIFROST_DEV_GATEWAY_PORT=8080
BIFROST_DEV_ADMIN_PORT=5173
BIFROST_DEV_POSTGRES_PORT=5432
