{
  "name": "@bifrost/desktop",
  "version": "0.0.0",
  "description": "Bifrost desktop client",
  "homepage": "https://github.com/kittors/Bifrost",
  "main": "out/main/index.js",
  "private": true,
  "type": "module",
  "author": {
    "name": "Kittors",
    "email": "14817208+kittors@users.noreply.github.com"
  },
  "scripts": {
    "build": "electron-vite build && tsc --noEmit",
    "check": "tsc --noEmit",
    "dev": "electron-vite dev",
    "dist:dir": "electron-builder --config electron-builder.yml --publish never --dir",
    "dist:linux": "electron-builder --config electron-builder.yml --publish never --linux AppImage deb tar.gz",
    "dist:mac": "electron-builder --config electron-builder.yml --publish never --mac dmg zip",
    "dist:win": "electron-builder --config electron-builder.yml --publish never --win nsis",
    "test": "vitest run"
  },
  "dependencies": {
    "@bifrost/contracts": "workspace:*",
    "@bifrost/design-tokens": "workspace:*",
    "@bifrost/ui": "workspace:*",
    "@tanstack/react-query": "5.99.0",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@bifrost/config-typescript": "workspace:*",
    "@bifrost/config-vitest": "workspace:*",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "electron": "41.2.1",
    "electron-builder": "26.8.1",
    "electron-vite": "6.0.0-beta.1",
    "happy-dom": "20.9.0",
    "typescript": "6.0.3"
  }
}
